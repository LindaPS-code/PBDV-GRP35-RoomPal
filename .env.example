# Copy this file to .env and replace the placeholder values.
# Recommended demo provider: Brevo free SMTP

SECRET_KEY=change-this-to-a-long-random-value
DATABASE_URL=sqlite:///instance/roommate_app.db
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
PREFERRED_URL_SCHEME=http
UPLOAD_FOLDER=uploads
EMAIL_PREVIEW_FOLDER=sent_emails

MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_brevo_smtp_login
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_DEFAULT_SENDER=your-verified-sender@example.com

SEED_DEFAULT_ADMIN=false
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
